PORT=5050
VITE_API_URL=http://localhost:5050

# Real AI image mockups are used automatically when OPENAI_API_KEY is set.
# Without a key, the app falls back to local SVG mockups.
# OPENAI_API_KEY=your_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
AI_MOCKUP_COUNT=3

# Optional: use Google Gemini image generation instead of OpenAI.
# AI_PROVIDER can be: cloudflare, gemini, openai
AI_PROVIDER=cloudflare
# GEMINI_API_KEY=your_google_ai_key_here
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: use a Cloudflare Worker image API.
# CLOUDFLARE_IMAGE_API_URL=https://your-worker.workers.dev
# CLOUDFLARE_IMAGE_API_KEY=your_cloudflare_worker_key
